generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id        String      @id @default(cuid())
  slug      String      @unique
  name      String
  emoji     String
  color     String
  price1      Int
  price3      Int
  isAvailable Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  orders    OrderItem[]
}

model Order {
  id            String      @id @default(cuid())
  code          String      @unique
  name          String
  whatsapp      String
  type          String
  kelas         String?
  total         Int
  status        String      @default("Baru")
  referralCode  String?
  affiliateCode String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  items         OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  qty       Int
  packaging String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

model Affiliate {
  id            String   @id @default(cuid())
  code          String   @unique
  ownerName     String
  ownerWA       String
  usedBy        String[] @default([])
  rewardClaimed Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  message   String
  type      String   @default("info")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
